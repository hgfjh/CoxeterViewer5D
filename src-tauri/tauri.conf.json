{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CoxeterViewer5D",
  "version": "0.1.0",
  "identifier": "org.coxeterviewer5d.viewer",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "corepack pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CoxeterViewer5D",
        "width": 1440,
        "height": 960,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "fileAssociations": [
      {
        "ext": ["coxeter-session"],
        "mimeType": "application/vnd.coxeter-viewer.session+json",
        "description": "CoxeterViewer5D session",
        "role": "Editor",
        "exportedType": {
          "identifier": "org.coxeterviewer5d.viewer.session",
          "conformsTo": ["public.json"]
        }
      },
      {
        "ext": ["coxeter-experiment"],
        "mimeType": "application/vnd.coxeter-viewer.experiment+json",
        "description": "CoxeterViewer5D experiment bundle",
        "role": "Viewer",
        "exportedType": {
          "identifier": "org.coxeterviewer5d.viewer.experiment",
          "conformsTo": ["public.json"]
        }
      }
    ]
  }
}
