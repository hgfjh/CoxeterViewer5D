{
  "name": "coxeter-viewer-5d",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --check .",
    "e2e": "playwright test",
    "session:validate": "node scripts/session_validate.mjs",
    "release:web": "node scripts/release_web.mjs",
    "release:desktop": "node scripts/release_desktop.mjs",
    "exact:certify": "python scripts/sage_export_backend.py --certify-output tests/fixtures/generated/I2_5_sage_radius_5.json tests/fixtures/generated/A2_sage_radius_3.json tests/fixtures/generated/A3_sage_radius_6.json",
    "certify:sage:i2-5": "python scripts/sage_export_backend.py --certify-output tests/fixtures/generated/I2_5_sage_radius_5.json",
    "certify:sage:a2": "python scripts/sage_export_backend.py --certify-output tests/fixtures/generated/A2_sage_radius_3.json",
    "certify:sage:a3": "python scripts/sage_export_backend.py --certify-output tests/fixtures/generated/A3_sage_radius_6.json",
    "certify:compact-5-cube": "python scripts/certify_compact_5_cube.py public/examples/compact_5_cube_gamma1.json",
    "certify:compact-5-prism": "python scripts/certify_compact_5_prism.py public/examples/compact_5_prism_makarov.json",
    "certify:geometry:compact-5-cube": "python scripts/certify_geometry_intervals.py public/examples/compact_5_cube_gamma1.json",
    "certify:geometry:compact-5-prism": "python scripts/certify_geometry_intervals.py public/examples/compact_5_prism_makarov.json",
    "check:coxiter:compact-5-cube": "python scripts/coxiter_check_compact.py public/examples/compact_5_cube_gamma1.json --require-external",
    "check:coxiter:compact-5-prism": "python scripts/coxiter_check_compact.py public/examples/compact_5_prism_makarov.json --require-external",
    "check:independent": "node scripts/check_independent.mjs",
    "validate:research-grade": "node scripts/validate_research_grade.mjs",
    "certify:gap:i2-5": "python scripts/gap_kbmag_export_backend.py --certify-output tests/fixtures/generated/I2_5_gap_radius_5.json",
    "certify:gap:a2": "python scripts/gap_kbmag_export_backend.py --certify-output tests/fixtures/generated/A2_gap_radius_3.json",
    "certify:gap:a3": "python scripts/gap_kbmag_export_backend.py --certify-output tests/fixtures/generated/A3_gap_radius_6.json",
    "verify:catalogue": "node scripts/verify_catalogue.mjs",
    "bench:catalogue": "node scripts/benchmark_catalogue.mjs",
    "bench:catalogue:write": "node scripts/benchmark_catalogue.mjs --write scripts/benchmarks/catalogue-static-v1.json",
    "bench:catalogue:check": "node scripts/benchmark_catalogue.mjs --check scripts/benchmarks/catalogue-static-v1.json",
    "bench:timed": "node scripts/benchmark_timed.mjs",
    "bench:timed:write": "node scripts/benchmark_timed.mjs --write scripts/benchmarks/timed-browser-v1.json",
    "bench:timed:check": "node scripts/benchmark_timed.mjs --check scripts/benchmarks/timed-browser-v1.json",
    "bench:timed:machine": "node scripts/benchmark_machine.mjs",
    "compare:backends": "node scripts/compare_backends.mjs",
    "compare:all-backends": "node scripts/compare_all_backends.mjs",
    "registry:validate": "node scripts/registry_validate.mjs",
    "adapter:validate": "node scripts/adapter_contract_validate.mjs",
    "schema:migrate": "node scripts/schema_migrate.mjs",
    "regenerate:all": "node scripts/regenerate_all.mjs",
    "demo:record": "node scripts/demo_record.mjs",
    "validate:artifact-manifest": "node scripts/validate_artifact_manifest.mjs scripts/certificates/external-artifact-manifest.example.json",
    "quotient:sage": "node scripts/certify_quotient.mjs tests/fixtures/quotients/I2_5_one_vertex_quotient.json",
    "quotient:gap": "node scripts/certify_quotient.mjs tests/fixtures/quotients/I2_5_one_vertex_quotient.json",
    "quotient:sage:export": "node scripts/run_quotient_export.mjs --backend sage --input tests/fixtures/quotients/I2_5_identity_subgroup_build_request.json",
    "quotient:gap:export": "node scripts/run_quotient_export.mjs --backend gap --input tests/fixtures/quotients/I2_5_identity_subgroup_build_request.json",
    "quotient:sage:export:i2-5-demo": "node scripts/run_quotient_export.mjs --backend sage --input tests/fixtures/quotients/I2_5_identity_subgroup_build_request.json",
    "quotient:gap:export:i2-5-demo": "node scripts/run_quotient_export.mjs --backend gap --input tests/fixtures/quotients/I2_5_identity_subgroup_build_request.json",
    "quotient:sage:export:a3-demo": "node scripts/run_quotient_export.mjs --backend sage --input tests/fixtures/quotients/A3_s02_subgroup_build_request.json",
    "quotient:gap:export:a3-demo": "node scripts/run_quotient_export.mjs --backend gap --input tests/fixtures/quotients/A3_s02_subgroup_build_request.json",
    "compare:quotient-backends": "node scripts/compare_quotient_backends.mjs",
    "workflow:validate": "node scripts/validate_workflow.mjs",
    "certify:quotient": "node scripts/certify_quotient.mjs tests/fixtures/quotients/I2_5_one_vertex_quotient.json",
    "certify:quotient:torsion-free": "node scripts/certify_quotient_torsion_free.mjs tests/fixtures/quotients/I2_5_one_vertex_quotient.json",
    "certify:morse": "node scripts/certify_morse.mjs tests/fixtures/quotients/I2_5_one_vertex_quotient.json",
    "certify:local-links": "node scripts/certify_local_links.mjs tests/fixtures/quotients/I2_5_one_vertex_quotient.json",
    "certify:davis-incidence": "node scripts/certify_davis_incidence.mjs tests/fixtures/generated/A3_sage_radius_6.json",
    "certify:geometry:intervals:compact-5-cube": "python scripts/certify_geometry_intervals.py public/examples/compact_5_cube_gamma1.json",
    "certify:geometry:intervals:compact-5-prism": "python scripts/certify_geometry_intervals.py public/examples/compact_5_prism_makarov.json",
    "notebook:validate": "node scripts/notebook_validate.mjs",
    "exact:sage:i2-5": "node scripts/run_sage_export.mjs --input public/examples/I2_5.json --radius 5 --created-at 2026-01-01T00:00:00.000Z --output tests/fixtures/generated/I2_5_sage_radius_5.json",
    "exact:sage:a2": "node scripts/run_sage_export.mjs --input public/examples/A2.json --radius 3 --created-at 2026-01-01T00:00:00.000Z --output tests/fixtures/generated/A2_sage_radius_3.json",
    "exact:sage:a3": "node scripts/run_sage_export.mjs --input public/examples/A3.json --radius 6 --created-at 2026-01-01T00:00:00.000Z --output tests/fixtures/generated/A3_sage_radius_6.json",
    "exact:gap:i2-5": "node scripts/run_gap_export.mjs --input public/examples/I2_5.json --radius 5 --created-at 2026-01-01T00:00:00.000Z --output tests/fixtures/generated/I2_5_gap_radius_5.json",
    "exact:gap:a2": "node scripts/run_gap_export.mjs --input public/examples/A2.json --radius 3 --created-at 2026-01-01T00:00:00.000Z --output tests/fixtures/generated/A2_gap_radius_3.json",
    "exact:gap:a3": "node scripts/run_gap_export.mjs --input public/examples/A3.json --radius 6 --created-at 2026-01-01T00:00:00.000Z --output tests/fixtures/generated/A3_gap_radius_6.json"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.555.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.181.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.55.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.181.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^16.0.0",
    "jsdom": "^27.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
